{
  "name": "agentic-planet",
  "version": "0.1.0",
  "private": true,
  "description": "The Agentic Planet — tools, MCPs, recipes and honest reviews for techies building with agents. Plain English.",
  "homepage": "https://agents.aguidetocloud.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/susanthgit/agentic-planet.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4323",
    "start": "astro dev --port 4323",
    "build": "astro build && pagefind --site dist",
    "build:no-search": "astro build",
    "preview": "astro preview --port 4323",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build:no-search && node scripts/deploy.mjs",
    "deploy:nobuild": "node scripts/deploy.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "pagefind": "^1.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
