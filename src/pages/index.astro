---
import BaseLayout from '@layouts/BaseLayout.astro';
import Panel from '@components/primitives/Panel.astro';
import Button from '@components/primitives/Button.astro';
import Icon from '@components/primitives/Icon.astro';
import Tag from '@components/primitives/Tag.astro';
import HealthBoard from '@components/panels/HealthBoard.astro';
import PillarTile from '@components/panels/PillarTile.astro';
import LiveDot from '@components/data/LiveDot.astro';
import PulseRail from '@components/panels/PulseRail.astro';
import ThisWeekPanel from '@components/panels/ThisWeekPanel.astro';
import AgenticStackDiagram from '@components/panels/AgenticStackDiagram.astro';
import CoverageMatrix from '@components/panels/CoverageMatrix.astro';
import TotalStarsMetric from '@components/panels/TotalStarsMetric.astro';
import MiniTerminal from '@components/panels/MiniTerminal.astro';
import RoadmapStrip from '@components/panels/RoadmapStrip.astro';
import DidYouKnow from '@components/panels/DidYouKnow.astro';
import StartHereRail from '@components/panels/StartHereRail.astro';
import FeaturedPicks from '@components/panels/FeaturedPicks.astro';
import Sparkline from '@components/data/Sparkline.astro';
import { getCollection } from 'astro:content';
import { computeUniqueRepoStars } from '@lib/counts';

import mcpHealth from '@data/mcp-health.json';
import pulseData from '@data/pulse.json';
import recipesData from '@data/featured-recipes.json';
import pillarsData from '@data/pillars.json';

const topMcps = mcpHealth.rows.slice(0, 8);
const featuredRecipes = recipesData.recipes.slice(0, 3);
const pillars = pillarsData.pillars;
const totals = { recipes: recipesData.recipes.length, mcps: mcpHealth.rows.length };

const reviewedMcps = await getCollection('mcps');
const reviewedSlugs = reviewedMcps.map((m) => m.id);

const { totalStars } = computeUniqueRepoStars(mcpHealth.rows);
function fmtK(n: number): string {
  if (n >= 1000000) return `${(n / 1000000).toFixed(1).replace('.0', '')}M`;
  if (n >= 1000) return `${Math.round(n / 1000)}k`;
  return n.toString();
}

const cronAge = Date.now() - new Date(mcpHealth._lastUpdated).getTime();
const cronH = Math.round(cronAge / 3600000);
const cronLabel = cronH < 1 ? '<1h' : `${cronH}h`;

const vendors = [
  { slug: 'microsoft', name: 'Microsoft', monogram: 'M', focus: 'Copilot Studio · Foundry · Agent 365', live: true, recent: 'Agent 365 GA next quarter' },
  { slug: 'anthropic', name: 'Anthropic', monogram: 'A', focus: 'Claude · MCP · Skills · Computer Use', live: true, recent: 'Computer Use v3 ships' },
  { slug: 'openai', name: 'OpenAI', monogram: 'O', focus: 'GPTs · Apps SDK · Operator', live: false, recent: 'Apps SDK adoption +12 this week' },
  { slug: 'google', name: 'Google', monogram: 'G', focus: 'Gemini · Vertex Agents · A2A', live: false, recent: 'A2A v0.4 spec drops' },
];

const faqs = [
  { slug: 'is-agentic-ai-hype', q: 'Is agentic AI hype?', tease: 'Some of it — most consumer demos are. The honest test: does it execute multi-step work without you holding its hand?' },
  { slug: 'will-mcp-survive', q: 'Will MCP survive 18 months?', tease: 'Probably yes. Claude Desktop adoption, GitHub MCP at 29.5k★, and OpenAI shipping a compatible Apps SDK adapter — that\'s a moat.' },
  { slug: 'build-with-zero-dollars', q: 'What can I build with $0?', tease: 'A capable research + writing + scheduling stack — Claude Free + GitHub MCP + Brave Search MCP + Filesystem MCP. Real workflows, no credit card.' },
  { slug: 'why-still-hallucinate', q: 'Why do agents still hallucinate?', tease: 'They\'re trained to predict plausible next-tokens, not to verify truth. RAG and tool-calls reduce it; nothing eliminates it. Always verify.' },
];

const featuredPillarSlugs = ['R02', 'M03'];
const featured = pillars.filter((p) => featuredPillarSlugs.includes(p.code)); void featured;
const standard = pillars.filter((p) => !featuredPillarSlugs.includes(p.code)); void standard;

function pillarCount(code: string): number {
  return pillars.find((p) => p.code === code)?.count ?? 0;
}

const heroStats = [
  { value: fmtK(totalStars), suffix: '★', label: 'tracked', color: 'cyan' },
  { value: String(pillarCount('M03')), suffix: '', label: 'mcps reviewed', color: 'cyan' },
  { value: String(totals.recipes), suffix: '', label: 'recipes', color: 'magenta' },
  { value: String(pillarCount('V05')), suffix: '', label: 'vendors', color: 'amber' },
  { value: String(pillarCount('P07')), suffix: '', label: 'standards', color: 'accent' },
  { value: String(pillarCount('S06')), suffix: '', label: 'safety lenses', color: 'red' },
];

// Ecosystem-at-a-glance: 7 mono telemetry tiles below the hero
const aliveCount = mcpHealth.rows.filter((r) => r.health === 'alive').length;
const slowingCount = mcpHealth.rows.filter((r) => r.health === 'slowing').length;
const totalDelta = mcpHealth.rows.reduce((sum, r) => sum + (r.delta7d ?? 0), 0);
const lastCommitDaysList = mcpHealth.rows
  .filter((r) => typeof r.lastCommitDays === 'number')
  .map((r) => r.lastCommitDays);
const avgFreshness = lastCommitDaysList.length
  ? Math.round(lastCommitDaysList.reduce((a, b) => a + b, 0) / lastCommitDaysList.length)
  : 0;
const categoryCounts = mcpHealth.rows.reduce<Record<string, number>>((acc, r) => {
  acc[r.category] = (acc[r.category] ?? 0) + 1;
  return acc;
}, {});
const topCategoryEntry = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1])[0];
const topCategoryName = topCategoryEntry ? topCategoryEntry[0] : '—';
const distinctCategories = Object.keys(categoryCounts).length;

const ecosystemStats = [
  { value: String(totals.mcps), label: 'tracked mcps', color: 'cyan' },
  { value: `${fmtK(totalStars)}★`, label: 'total stars', color: 'cyan' },
  { value: `+${totalDelta}`, label: 'stars / 7d', color: 'green' },
  { value: String(aliveCount), label: 'alive', color: 'green' },
  { value: String(slowingCount), label: 'slowing', color: 'amber' },
  { value: `${avgFreshness}d`, label: 'avg freshness', color: 'mute' },
  { value: topCategoryName, label: 'top category', color: 'accent' },
  { value: String(distinctCategories), label: 'categories', color: 'mute' },
];

// Top movers — top 8 MCPs by 7-day star delta (matches HealthBoard row count)
const topMovers = [...mcpHealth.rows]
  .filter((r) => (r.delta7d ?? 0) > 0 && r.sourceType !== 'monorepo-subdir')
  .sort((a, b) => (b.delta7d ?? 0) - (a.delta7d ?? 0))
  .slice(0, 8);

// Quick install snippets — popular MCPs, all reviewed
const quickInstalls = [
  { slug: 'github-mcp', name: 'GitHub', cmd: 'npx -y @github/mcp-server', category: 'Dev' },
  { slug: 'playwright-mcp', name: 'Playwright', cmd: 'npx -y @playwright/mcp', category: 'Browser' },
  { slug: 'filesystem-mcp', name: 'Filesystem', cmd: 'npx -y @modelcontextprotocol/server-filesystem', category: 'Dev' },
  { slug: 'postgres-mcp', name: 'Postgres', cmd: 'npx -y @modelcontextprotocol/server-postgres', category: 'Data' },
];

const coverage = pillars.map((p) => ({
  code: p.code,
  title: p.title,
  href: p.href,
  current: p.count ?? 0,
  target: p.target ?? p.count ?? 1,
  color: p.color as 'accent' | 'cyan' | 'green' | 'amber' | 'red' | 'magenta' | 'violet',
  icon: p.icon as 'globe' | 'flask' | 'plug' | 'wrench' | 'building' | 'shield' | 'book' | 'brain' | 'beaker' | 'help',
  status: p.fillPercent === 100 ? 'COMPLETE' : p.fillPercent >= 50 ? 'IN-PROGRESS' : 'EARLY',
}));

const featuredRecipe = {
  slug: featuredRecipes[0]?.slug ?? 'youtube-seo-automation',
  title: featuredRecipes[0]?.title ?? 'Automate YouTube SEO',
  description: featuredRecipes[0]?.description ?? '',
  components: featuredRecipes[0]?.components ?? [],
  before: featuredRecipes[0]?.before ?? '',
  after: featuredRecipes[0]?.after ?? '',
  cost: featuredRecipes[0]?.cost ?? undefined,
  status: featuredRecipes[0]?.status ?? 'draft',
};

const featuredMcp = {
  slug: 'github-mcp',
  name: 'github-mcp-server',
  category: 'Dev',
  summary: 'Official GitHub MCP server. Browse, search, and modify repos, issues, PRs, Actions from any MCP-aware agent. Maintained by GitHub.',
  health: 'alive' as const,
  stars: mcpHealth.rows.find((r) => r.slug === 'github-mcp')?.stars ?? 29550,
};
---

<BaseLayout
  title="The Agentic Planet — honest reviews of agentic AI tools"
  description="Honest reviews, health-board MCP coverage, recipes, and plain-English explainers for techies building AI agents. No vendor spin, no hype — just what works."
>
  <section class="hero container-wide">
    <div class="hero__scan" aria-hidden="true"></div>

    <div class="hero__top">
      <span class="hero__kicker mono">
        <LiveDot color="green" size="sm" />
        <span>AGENTS // FIELD GUIDE // ONLINE</span>
      </span>
      <span class="hero__count mono">cron {cronLabel} ago</span>
    </div>

    <div class="hero__main">
      <div class="hero__body">
        <h1 class="hero__title">
          A field guide for <span class="hero__title-accent">building with agents.</span><span class="hero__cursor" aria-hidden="true">▌</span>
        </h1>

        <p class="hero__sub">
          Vendor docs are pitch. Hacker News is a lottery. <strong>Honest MCP reviews, side-by-side vendor takes, and recipes with measured numbers</strong> — by an engineer who deploys this for a living.
        </p>

        <div class="hero__cta">
          <Button href="/lab/pick-your-stack/" variant="primary"><Icon name="beaker" size={14} /> Pick Your Stack →</Button>
          <Button href="/recipes/" variant="ghost"><Icon name="flask" size={14} /> Browse Recipes</Button>
          <Button href="/learn/what-is-an-agent/" variant="ghost"><Icon name="help" size={14} /> What is this?</Button>
        </div>

        <dl class="hero__stats" aria-label="Site coverage at a glance">
          {heroStats.map((s) => (
            <div class="hero__stat">
              <dt class={`hero__stat-val hero__stat-val--${s.color} mono`}>
                {s.value}<span class="hero__stat-suffix">{s.suffix}</span>
              </dt>
              <dd class="hero__stat-label mono">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <aside class="hero__visual" aria-label="The agentic stack at a glance">
        <AgenticStackDiagram />
      </aside>
    </div>
  </section>

  <section class="container-wide section section--tight">
    <div class="ecosys-strip" role="region" aria-label="Ecosystem at a glance">
      <span class="ecosys-strip__label mono">
        <LiveDot color="cyan" size="sm" />
        <span>ECOSYSTEM // 24H SNAPSHOT</span>
      </span>
      <div class="ecosys-strip__items">
        {ecosystemStats.map((s) => (
          <span class="ecosys-stat">
            <span class={`ecosys-stat__val mono ecosys-stat__val--${s.color}`}>{s.value}</span>
            <span class="ecosys-stat__lbl mono">{s.label}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="container-wide section section--tight">
    <StartHereRail />
  </section>

  <section class="container-wide section">
    <header class="section-head">
      <span class="section-kicker mono">▸ WHAT'S MOVING NOW // LIVE STREAM</span>
      <h2 class="section-title">Cron-fed updates from the agentic ecosystem.</h2>
      <p class="section-lede">
        Vendor releases, protocol changes, MCP star deltas, recently committed servers — auto-refreshed every 6 hours.
      </p>
    </header>

    <div class="bento bento--50-50">
      <div class="bento__cell">
        <PulseRail items={pulseData.items} limit={5} />
      </div>
      <div class="bento__cell">
        <ThisWeekPanel rows={mcpHealth.rows} lastUpdated={mcpHealth._lastUpdated} />
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <header class="section-head">
      <span class="section-kicker mono">▸ EXPLORE BY PILLAR // 10 SURFACES</span>
      <h2 class="section-title">Everything we cover, with progress visible.</h2>
      <p class="section-lede">
        Each pillar shows current/target. Some are complete (Standards 4/4), others growing (MCPs 13/30).
      </p>
    </header>

    <div class="pillars-bento">
      {pillars.map((p) => (
        <div class="pillars-bento__cell">
          <PillarTile href={p.href} code={p.code} title={p.title} description={p.description} count={p.count} target={p.target} fillPercent={p.fillPercent} color={p.color as 'accent' | 'cyan' | 'green' | 'amber' | 'magenta' | 'violet'} icon={p.icon as 'globe' | 'flask' | 'plug' | 'wrench' | 'building' | 'shield' | 'book' | 'brain' | 'beaker' | 'help'} />
        </div>
      ))}
    </div>
  </section>

  <section class="container-wide section">
    <FeaturedPicks recipe={featuredRecipe} mcp={featuredMcp} />
  </section>

  <section class="container-wide section">
    <header class="section-head">
      <span class="section-kicker mono">▸ DEEP DATA // CATALOG + WORKFLOWS</span>
      <h2 class="section-title">The core surfaces.</h2>
    </header>

    <div class="bento bento--60-40">
      <div class="bento__cell">
        <Panel
          title={`MCP Health Board · top ${topMcps.length}`}
          kicker="LIVE"
          meta={`Updated ${new Date(mcpHealth._lastUpdated).toUTCString().replace('GMT', 'UTC')}`}
          variant="cyan"
          density="tight"
        >
          <HealthBoard rows={topMcps} compact={false} reviewedSlugs={reviewedSlugs} />
          <div slot="footer" class="bento__footer">
            <Button href="/mcp/" variant="ghost" size="sm">Full board <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>

      <div class="bento__cell">
        <Panel kicker="TOP MOVERS · 7D" title="MCPs gaining traction" variant="default" density="tight">
          <div class="topmovers">
            {topMovers.map((m, i) => (
              <a class="tmover" href={reviewedSlugs.includes(m.slug) ? `/mcp/${m.slug}/` : '/mcp/'}>
                <span class="tmover__rank mono">{String(i + 1).padStart(2, '0')}</span>
                <span class="tmover__name">{m.name}</span>
                <span class="tmover__cat mono">{m.category}</span>
                <span class="tmover__delta mono phosphor-green">+{m.delta7d}</span>
                <span class="tmover__stars mono">{fmtK(m.stars)}★</span>
                <span class="tmover__trend">
                  {m.trend && m.trend.length > 0 ? (
                    <Sparkline data={m.trend} stroke="green" width={48} height={16} />
                  ) : (
                    <span class="tmover__trend-empty mono">—</span>
                  )}
                </span>
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/mcp/" variant="ghost" size="sm">All MCPs <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--50-50">
      <div class="bento__cell">
        <Panel kicker="HONEST FAQ" title="Big questions" variant="default" density="tight">
          <div class="faq-stack">
            {faqs.map((f, i) => (
              <a class="qline" href={`/faq/${f.slug}/`}>
                <span class="qline__num mono">Q.{String(i + 1).padStart(2, '0')}</span>
                <span class="qline__main">
                  <span class="qline__q">{f.q}</span>
                  <span class="qline__tease">{f.tease}</span>
                </span>
                <Icon name="chevron-right" size={14} />
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/faq/" variant="ghost" size="sm">All FAQ answers <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>

      <div class="bento__cell">
        <Panel kicker="VENDOR FILES" title="Side-by-side, no spin" variant="default" density="tight">
          <div class="vendor-stack">
            {vendors.map((v) => (
              <a class:list={['vbrick', !v.live && 'vbrick--soon']} href={v.live ? `/vendors/${v.slug}/` : '/vendors/'}>
                <span class="vbrick__mono mono">{v.monogram}</span>
                <span class="vbrick__main">
                  <span class="vbrick__name">{v.name}</span>
                  <span class="vbrick__focus mono">{v.focus}</span>
                  <span class="vbrick__recent">
                    <Icon name="arrow-right" size={9} /> {v.recent}
                  </span>
                </span>
                {v.live ? <span class="vbrick__status mono phosphor-green">LIVE</span> : <span class="vbrick__status mono">PHASE 2</span>}
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/vendors/" variant="ghost" size="sm">All vendors <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--60-40">
      <div class="bento__cell">
        <RoadmapStrip />
      </div>
      <div class="bento__cell">
        <Panel kicker="QUICK INSTALL" title="Add an MCP in 30 seconds" variant="cyan" density="tight">
          <div class="qi">
            {quickInstalls.map((q) => (
              <div class="qi__row">
                <span class="qi__label">
                  <span class="qi__name">{q.name}</span>
                  <span class="qi__cat mono">{q.category}</span>
                </span>
                <code class="qi__cmd mono">{q.cmd}</code>
                <button class="qi__copy" data-copy={q.cmd} aria-label={`Copy ${q.name} install command`}>
                  <Icon name="file-code" size={12} />
                  <span class="sr-only">Copy</span>
                </button>
              </div>
            ))}
            <p class="qi__hint mono">CONFIG → ~/.config/Claude/claude_desktop_config.json</p>
            <div class="qi__cta">
              <Button href="/mcp/" variant="ghost" size="sm">Browse all MCPs <Icon name="arrow-right" size={11} /></Button>
            </div>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--40-60">
      <div class="bento__cell mobile-hide">
        <MiniTerminal />
      </div>
      <div class="bento__cell">
        <Panel kicker="EXPLAINERS" title="Plain English, no jargon" density="tight">
          <div class="explainer-row">
            <a class="exline" href="/learn/mcp-in-90-seconds/">
              <Icon name="brain" size={14} />
              <span class="exline__title">MCP in 90 seconds</span>
              <span class="exline__depth mono">90s</span>
            </a>
            <a class="exline" href="/learn/what-is-an-agent/">
              <Icon name="brain" size={14} />
              <span class="exline__title">What is an agent?</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/agentic-loops/">
              <Icon name="brain" size={14} />
              <span class="exline__title">How agentic loops work</span>
              <span class="exline__depth mono">DEEP</span>
            </a>
            <a class="exline" href="/learn/tool-calling-vs-mcp/">
              <Icon name="brain" size={14} />
              <span class="exline__title">Tool calling vs MCP</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/what-is-agentic/">
              <Icon name="brain" size={14} />
              <span class="exline__title">What "agentic" means</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/glossary/">
              <Icon name="search" size={14} />
              <span class="exline__title">Glossary (26 terms)</span>
              <span class="exline__depth mono">A–Z</span>
            </a>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--60-40">
      <div class="bento__cell">
        <CoverageMatrix pillars={coverage} />
      </div>
      <div class="bento__cell">
        <TotalStarsMetric rows={mcpHealth.rows} />
      </div>
    </div>
  </section>

  <section class="container-wide section section--ultra-tight">
    <DidYouKnow />
  </section>
</BaseLayout>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-copy]');
    if (!btn) return;
    const text = btn.dataset.copy ?? '';
    navigator.clipboard.writeText(text).then(() => {
      btn.classList.add('is-copied');
      const span = btn.querySelector('span:not(.sr-only)');
      const orig = span?.textContent ?? '';
      if (span) span.textContent = 'Copied';
      setTimeout(() => {
        btn.classList.remove('is-copied');
        if (span) span.textContent = orig;
      }, 1500);
    });
  });

  let lastG = 0;
  const PILLAR_KEYS: Record<string, string> = {
    r: '/recipes/', m: '/mcp/', l: '/landscape/', t: '/tools/', v: '/vendors/',
    s: '/safety/', p: '/standards/', h: '/learn/', x: '/lab/', q: '/faq/',
  };

  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const target = e.target as HTMLElement;
    if (target && /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName)) return;
    const now = Date.now();
    if (e.key === 'g' || e.key === 'G') { lastG = now; return; }
    if (now - lastG < 1200) {
      const dest = PILLAR_KEYS[e.key.toLowerCase()];
      if (dest) { e.preventDefault(); lastG = 0; window.location.href = dest; }
    }
  });
</script>

<style>
  .section { padding: var(--space-5) 0; }
  .section--tight { padding: var(--space-3) 0; }
  .section--ultra-tight { padding: var(--space-2) 0; }

  /* Mobile strip-down: hide cells/panels at phone widths. */
  @media (max-width: 700px) {
    .mobile-hide { display: none !important; }
  }

  .section-head { margin-bottom: var(--space-3); max-width: 720px; }
  .section-kicker {
    display: inline-block;
    font-size: var(--fs-2xs);
    font-weight: var(--fw-semibold);
    color: var(--accent-hi);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-1);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, var(--fs-xl));
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-2) 0;
  }
  .section-lede {
    font-size: var(--fs-sm);
    color: var(--text-mute);
    line-height: 1.5;
    margin: 0;
    max-width: 640px;
  }

  .hero {
    position: relative;
    margin-top: var(--space-3);
    padding: var(--space-6) var(--gutter) var(--space-6);
    background:
      radial-gradient(ellipse 60% 60% at 0% 0%, rgba(99, 102, 241, 0.08), transparent 60%),
      var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .hero__scan {
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--signal-cyan), transparent);
    opacity: 0.5;
  }
  .hero__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
