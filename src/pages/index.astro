---
import BaseLayout from '@layouts/BaseLayout.astro';
import Panel from '@components/primitives/Panel.astro';
import Button from '@components/primitives/Button.astro';
import Icon from '@components/primitives/Icon.astro';
import Tag from '@components/primitives/Tag.astro';
import HealthBoard from '@components/panels/HealthBoard.astro';
import PillarTile from '@components/panels/PillarTile.astro';
import LiveDot from '@components/data/LiveDot.astro';
import PulseRail from '@components/panels/PulseRail.astro';
import ThisWeekPanel from '@components/panels/ThisWeekPanel.astro';
import AgenticStackDiagram from '@components/panels/AgenticStackDiagram.astro';

import mcpHealth from '@data/mcp-health.json';
import pulseData from '@data/pulse.json';
import recipesData from '@data/featured-recipes.json';
import pillarsData from '@data/pillars.json';

const topMcps = mcpHealth.rows.slice(0, 5);
const featuredRecipes = recipesData.recipes.slice(0, 3);
const pillars = pillarsData.pillars;
const totals = { recipes: recipesData.recipes.length, mcps: mcpHealth.rows.length };

const vendors = [
  { slug: 'microsoft', name: 'Microsoft', monogram: 'M', focus: 'Copilot Studio · Foundry · Agent 365', live: true, recent: 'Agent 365 GA next quarter' },
  { slug: 'anthropic', name: 'Anthropic', monogram: 'A', focus: 'Claude · MCP · Skills · Computer Use', live: true, recent: 'Computer Use v3 ships' },
  { slug: 'openai', name: 'OpenAI', monogram: 'O', focus: 'GPTs · Apps SDK · Operator', live: false, recent: 'Apps SDK adoption +12 this week' },
  { slug: 'google', name: 'Google', monogram: 'G', focus: 'Gemini · Vertex Agents · A2A', live: false, recent: 'A2A v0.4 spec drops' },
];

const faqs = [
  { slug: 'is-agentic-ai-hype', q: 'Is agentic AI hype?', hint: 'Some of it. Here is how to tell.' },
  { slug: 'will-mcp-survive', q: 'Will MCP survive 18 months?', hint: 'Probably yes. Here is why.' },
  { slug: 'build-with-zero-dollars', q: 'What can I build with $0?', hint: 'More than you think.' },
  { slug: 'why-still-hallucinate', q: 'Why do agents still hallucinate?', hint: 'Pattern completion vs truth.' },
];

const featuredPillarSlugs = ['R02', 'M03'];
const featured = pillars.filter((p) => featuredPillarSlugs.includes(p.code));
const standard = pillars.filter((p) => !featuredPillarSlugs.includes(p.code));
---

<BaseLayout
  title="The Agentic Planet"
  description="Tools, MCPs, recipes, and honest reviews for techies building with agents. Plain English. No vendor spin."
>
  <section class="bridge container-wide">
    <div class="bridge__scan" aria-hidden="true"></div>

    <div class="bridge__top">
      <span class="bridge__kicker mono">
        <LiveDot color="green" size="sm" />
        <span>AGENTS // FIELD GUIDE // CHANNEL OPEN</span>
      </span>
      <span class="bridge__count mono">{pillars.length} PILLARS · {totals.mcps} MCPs · {totals.recipes} RECIPES · 0 SPONSORED</span>
    </div>

    <div class="bridge__main">
      <div class="bridge__left">
        <h1 class="bridge__title">
          <span class="bridge__line">A field guide for</span>
          <span class="bridge__line bridge__line--accent">building with agents.</span><span class="bridge__cursor" aria-hidden="true">▌</span>
        </h1>
        <p class="bridge__sub">
          Tools, MCPs, recipes, and honest reviews for techies. Plain English. No vendor spin. Built by an engineer who deploys this for a living — and writes about it because the gap is real.
        </p>

        <div class="bridge__cta">
          <Button href="/recipes/" variant="primary"><Icon name="flask" size={14} /> Browse Recipes</Button>
          <Button href="/mcp/" variant="ghost"><Icon name="plug" size={14} /> MCP Health Board</Button>
          <Button href="/lab/pick-your-stack/" variant="ghost"><Icon name="beaker" size={14} /> Pick Your Stack</Button>
        </div>

        <div class="bridge__hints">
          <span class="bridge__hint mono"><kbd>⌘K</kbd> Quick jump</span>
          <span class="bridge__hint mono"><kbd>G</kbd>+<kbd>R</kbd> Recipes</span>
          <span class="bridge__hint mono"><kbd>G</kbd>+<kbd>M</kbd> MCPs</span>
          <span class="bridge__hint mono"><kbd>G</kbd>+<kbd>L</kbd> Landscape</span>
        </div>
      </div>

      <div class="bridge__right">
        <PulseRail items={pulseData.items} limit={4} />
        <ThisWeekPanel rows={mcpHealth.rows} lastUpdated={mcpHealth._lastUpdated} />
      </div>
    </div>
  </section>

  <section class="container-wide section section--tight">
    <header class="section-head">
      <span class="section-kicker mono">▸ TEN PILLARS // SYSTEM SURFACES</span>
      <h2 class="section-title">Everything we cover, by surface.</h2>
    </header>

    <div class="pillars-bento">
      {featured.map((p) => (
        <div class="pillars-bento__cell pillars-bento__cell--feature">
          <PillarTile href={p.href} code={p.code} title={p.title} description={p.description} count={p.count} fillPercent={p.fillPercent} color={p.color} icon={p.icon} />
        </div>
      ))}
      {standard.slice(0, 2).map((p) => (
        <div class="pillars-bento__cell">
          <PillarTile href={p.href} code={p.code} title={p.title} description={p.description} count={p.count} fillPercent={p.fillPercent} color={p.color} icon={p.icon} />
        </div>
      ))}
      {standard.slice(2).map((p) => (
        <div class="pillars-bento__cell">
          <PillarTile href={p.href} code={p.code} title={p.title} description={p.description} count={p.count} fillPercent={p.fillPercent} color={p.color} icon={p.icon} />
        </div>
      ))}
    </div>
  </section>

  <!-- AGENTIC STACK — signature visual -->
  <section class="container-wide section">
    <AgenticStackDiagram />
  </section>

  <section class="container-wide section">
    <div class="bento bento--60-40">
      <div class="bento__cell">
        <Panel title={`MCP Health Board · top ${topMcps.length}`} kicker="SEED" meta={`Updated ${new Date(mcpHealth._lastUpdated).toUTCString().replace('GMT', 'UTC')}`} variant="cyan" density="tight">
          <HealthBoard rows={topMcps} compact={false} />
          <div slot="footer" class="bento__footer">
            <Button href="/mcp/" variant="ghost" size="sm">Full board <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>

      <div class="bento__cell">
        <Panel kicker="MOAT" title="Top Recipes" variant="default" density="tight">
          <div class="rstack">
            {featuredRecipes.map((r) => (
              <a class="rmini" href={`/recipes/${r.slug}/`}>
                <div class="rmini__head">
                  <Icon name="flask" size={14} />
                  <h4 class="rmini__title">{r.title}</h4>
                </div>
                <div class="rmini__metrics">
                  <span class="rmini__before">{r.before}</span>
                  <Icon name="arrow-right" size={10} />
                  <span class="rmini__after phosphor-green mono">{r.after}</span>
                  {r.cost && <span class="rmini__cost mono">· {r.cost}</span>}
                </div>
                <div class="rmini__tags">
                  {r.components.slice(0, 3).map((c) => <Tag text={c} color="cyan" />)}
                </div>
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/recipes/" variant="ghost" size="sm">All recipes <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--50-50">
      <div class="bento__cell">
        <Panel kicker="HONEST FAQ" title="Big questions" variant="default" density="tight">
          <div class="faq-stack">
            {faqs.map((f, i) => (
              <a class="qline" href={`/faq/${f.slug}/`}>
                <span class="qline__num mono">Q.{String(i + 1).padStart(2, '0')}</span>
                <span class="qline__main">
                  <span class="qline__q">{f.q}</span>
                  <span class="qline__hint">{f.hint}</span>
                </span>
                <Icon name="chevron-right" size={14} />
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/faq/" variant="ghost" size="sm">All FAQ answers <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>

      <div class="bento__cell">
        <Panel kicker="VENDOR FILES" title="Side-by-side, no spin" variant="default" density="tight">
          <div class="vendor-stack">
            {vendors.map((v) => (
              <a class:list={['vbrick', !v.live && 'vbrick--soon']} href={v.live ? `/vendors/${v.slug}/` : '/vendors/'}>
                <span class="vbrick__mono mono">{v.monogram}</span>
                <span class="vbrick__main">
                  <span class="vbrick__name">{v.name}</span>
                  <span class="vbrick__focus mono">{v.focus}</span>
                  <span class="vbrick__recent">
                    <Icon name="arrow-right" size={9} /> {v.recent}
                  </span>
                </span>
                {v.live ? <span class="vbrick__status mono phosphor-green">LIVE</span> : <span class="vbrick__status mono">SOON</span>}
              </a>
            ))}
          </div>
          <div slot="footer" class="bento__footer">
            <Button href="/vendors/" variant="ghost" size="sm">All vendors <Icon name="arrow-right" size={12} /></Button>
          </div>
        </Panel>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="bento bento--60-40">
      <div class="bento__cell">
        <Panel kicker="EXPLAINERS" title="Plain English, no jargon" density="tight">
          <div class="explainer-row">
            <a class="exline" href="/learn/mcp-in-90-seconds/">
              <Icon name="brain" size={14} />
              <span class="exline__title">MCP in 90 seconds</span>
              <span class="exline__depth mono">90s</span>
            </a>
            <a class="exline" href="/learn/what-is-an-agent/">
              <Icon name="brain" size={14} />
              <span class="exline__title">What is an agent?</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/agentic-loops/">
              <Icon name="brain" size={14} />
              <span class="exline__title">How agentic loops work</span>
              <span class="exline__depth mono">DEEP</span>
            </a>
            <a class="exline" href="/learn/tool-calling-vs-mcp/">
              <Icon name="brain" size={14} />
              <span class="exline__title">Tool calling vs MCP</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/what-is-agentic/">
              <Icon name="brain" size={14} />
              <span class="exline__title">What "agentic" means</span>
              <span class="exline__depth mono">5m</span>
            </a>
            <a class="exline" href="/learn/glossary/">
              <Icon name="search" size={14} />
              <span class="exline__title">Glossary (26 terms)</span>
              <span class="exline__depth mono">A–Z</span>
            </a>
          </div>
        </Panel>
      </div>

      <div class="bento__cell">
        <Panel kicker="TRY IT" title="Install MCP in 30 seconds" variant="cyan" density="tight">
          <div class="install">
            <p class="install__lead">Add the GitHub MCP server to Claude Desktop:</p>
            <div class="install__code">
              <code>npx -y @github/mcp-server</code>
              <button class="install__copy" data-copy="npx -y @github/mcp-server" aria-label="Copy command">
                <Icon name="file-code" size={12} />
                <span>Copy</span>
              </button>
            </div>
            <p class="install__hint mono">CONFIG → ~/.config/Claude/claude_desktop_config.json</p>
            <div class="install__cta">
              <Button href="/mcp/github-mcp/" variant="ghost" size="sm">Full setup <Icon name="arrow-right" size={11} /></Button>
            </div>
          </div>
        </Panel>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-copy]');
    if (!btn) return;
    const text = btn.dataset.copy ?? '';
    navigator.clipboard.writeText(text).then(() => {
      const span = btn.querySelector('span');
      if (!span) return;
      const orig = span.textContent;
      span.textContent = 'Copied';
      btn.classList.add('install__copy--done');
      setTimeout(() => { span.textContent = orig; btn.classList.remove('install__copy--done'); }, 1500);
    });
  });

  let lastG = 0;
  const PILLAR_KEYS: Record<string, string> = {
    r: '/recipes/', m: '/mcp/', l: '/landscape/', t: '/tools/', v: '/vendors/',
    s: '/safety/', p: '/standards/', h: '/learn/', x: '/lab/', q: '/faq/',
  };

  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const target = e.target as HTMLElement;
    if (target && /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName)) return;
    const now = Date.now();
    if (e.key === 'g' || e.key === 'G') { lastG = now; return; }
    if (now - lastG < 1200) {
      const dest = PILLAR_KEYS[e.key.toLowerCase()];
      if (dest) { e.preventDefault(); lastG = 0; window.location.href = dest; }
    }
  });
</script>

<style>
  .section { padding: var(--space-5) 0; }
  .section--tight { padding: var(--space-3) 0; }

  .section-head { margin-bottom: var(--space-3); max-width: 720px; }
  .section-kicker {
    display: inline-block;
    font-size: var(--fs-2xs);
    font-weight: var(--fw-semibold);
    color: var(--accent-hi);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    margin-bottom: var(--space-1);
    text-shadow: var(--text-glow-accent);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, var(--fs-xl));
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .bridge {
    position: relative;
    margin-top: var(--space-3);
    padding: var(--space-5) var(--gutter) var(--space-5);
    background: radial-gradient(ellipse 60% 40% at 0% 0%, rgba(99, 102, 241, 0.10), transparent 60%), var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .bridge__scan {
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--signal-cyan), transparent);
    opacity: 0.7; box-shadow: 0 0 8px var(--accent-glow);
  }
  .bridge__top {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: var(--space-3); border-bottom: 1px solid var(--border-dim);
    margin-bottom: var(--space-4); flex-wrap: wrap; gap: var(--space-2);
  }
  .bridge__kicker {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-size: var(--fs-2xs); color: var(--accent-hi);
    text-transform: uppercase; letter-spacing: var(--tracking-widest);
    font-weight: var(--fw-semibold);
  }
  .bridge__count {
    font-size: var(--fs-2xs); color: var(--text-mute);
    text-transform: uppercase; letter-spacing: var(--tracking-wider);
  }
  .bridge__main {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: var(--space-5);
  }
  @media (max-width: 1000px) { .bridge__main { grid-template-columns: 1fr; } }
  .bridge__left { display: flex; flex-direction: column; gap: var(--space-3); align-self: center; }
  .bridge__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: var(--fw-bold);
    line-height: 1; letter-spacing: -0.04em;
    color: var(--text-bright); margin: 0;
    display: flex; flex-direction: column; gap: 1px;
  }
  .bridge__line { display: block; }
  .bridge__line--accent { color: var(--accent-hi); text-shadow: 0 0 16px var(--accent-glow); }
  .bridge__cursor {
    display: inline-block; color: var(--accent-hi);
    animation: blink 1.1s infinite step-start;
    text-shadow: var(--text-glow-accent);
    margin-left: 4px; line-height: 1;
  }
  .bridge__sub { font-size: var(--fs-sm); line-height: 1.5; color: var(--text-mute); margin: 0; max-width: 540px; }
  .bridge__cta { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .bridge__hints {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
    padding-top: var(--space-2); border-top: 1px dashed var(--border-dim);
    font-size: var(--fs-2xs); color: var(--text-faint);
    text-transform: uppercase; letter-spacing: var(--tracking-wider);
  }
  .bridge__hint { display: inline-flex; align-items: center; gap: 4px; }
  .bridge__hint :global(kbd) {
    background: var(--bg-elevated); color: var(--text-bright);
    padding: 1px 5px; border: 1px solid var(--border);
    border-bottom-width: 2px; border-radius: var(--radius-xs);
    font-family: var(--font-mono); font-size: 10px; font-weight: var(--fw-bold);
  }
  .bridge__right {
    display: grid; grid-template-columns: 1fr; grid-template-rows: auto auto;
    gap: var(--space-2-5); min-width: 0;
  }

  .pillars-bento {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: var(--space-2);
  }
  .pillars-bento__cell { min-width: 0; }
  .pillars-bento__cell--feature { grid-column: span 2; }
  @media (max-width: 1100px) {
    .pillars-bento { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .pillars-bento__cell--feature { grid-column: span 2; }
  }
  @media (max-width: 700px) {
    .pillars-bento { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .pillars-bento__cell--feature { grid-column: span 2; }
  }

  .bento { display: grid; gap: var(--space-3); }
  .bento--60-40 { grid-template-columns: 1.5fr 1fr; }
  .bento--50-50 { grid-template-columns: 1fr 1fr; }
  @media (max-width: 1000px) { .bento--60-40, .bento--50-50 { grid-template-columns: 1fr; } }
  .bento__cell { min-width: 0; }
  .bento__footer {
    display: flex; justify-content: flex-end;
    padding: var(--space-2) var(--space-3);
    border-top: 1px solid var(--border-dim);
    background: var(--bg-elevated);
  }

  .rstack { display: flex; flex-direction: column; gap: var(--space-2); }
  .rmini {
    display: flex; flex-direction: column; gap: var(--space-1-5);
    padding: var(--space-2-5);
    background: var(--bg-base); border: 1px solid var(--border-dim);
    border-radius: var(--radius-xs); border-left: 2px solid var(--signal-magenta);
    color: var(--text); transition: all var(--duration-fast) var(--ease-out);
  }
  .rmini:hover { border-color: var(--signal-magenta); background: var(--bg-elevated); }
  .rmini__head { display: flex; align-items: center; gap: var(--space-2); color: var(--signal-magenta); }
  .rmini__title { font-family: var(--font-display); font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-bright); margin: 0; line-height: 1.2; letter-spacing: var(--tracking-tight); }
  .rmini__metrics { display: flex; align-items: center; gap: var(--space-1-5); font-family: var(--font-mono); font-size: 11px; }
  .rmini__before { color: var(--text-mute); text-decoration: line-through; text-decoration-color: var(--signal-red); }
  .rmini__after { font-weight: var(--fw-semibold); }
  .rmini__cost { color: var(--text-faint); margin-left: auto; }
  .rmini__tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .faq-stack { display: flex; flex-direction: column; }
  .qline {
    display: grid; grid-template-columns: 56px 1fr auto;
    align-items: center; gap: var(--space-3);
    padding: var(--space-2-5) 0; border-bottom: 1px solid var(--border-dim);
    color: var(--text); transition: all var(--duration-fast) var(--ease-out);
  }
  .qline:last-child { border-bottom: 0; }
  .qline:hover { background: var(--bg-elevated); margin: 0 calc(-1 * var(--space-3)); padding: var(--space-2-5) var(--space-3); color: var(--text-bright); }
  .qline__num { font-size: var(--fs-2xs); color: var(--signal-amber); text-transform: uppercase; letter-spacing: var(--tracking-widest); text-shadow: var(--text-glow-amber); font-weight: var(--fw-bold); }
  .qline__main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .qline__q { font-family: var(--font-display); font-size: var(--fs-sm); color: var(--text-bright); line-height: 1.2; }
  .qline__hint { font-size: var(--fs-xs); color: var(--text-mute); }
  .qline > :global(.icon) { color: var(--text-faint); }
  .qline:hover > :global(.icon) { color: var(--signal-amber); }

  .vendor-stack { display: flex; flex-direction: column; gap: var(--space-1-5); }
  .vbrick {
    display: grid; grid-template-columns: 36px 1fr auto;
    align-items: center; gap: var(--space-3); padding: var(--space-2-5);
    background: var(--bg-base); border: 1px solid var(--border-dim);
    border-left: 2px solid var(--signal-amber); border-radius: var(--radius-xs);
    color: var(--text); transition: all var(--duration-fast) var(--ease-out);
  }
  .vbrick:hover { border-color: var(--signal-amber); background: var(--bg-elevated); }
  .vbrick--soon { opacity: 0.6; }
  .vbrick__mono {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--bg-elevated); border: 1px solid var(--signal-amber);
    border-radius: var(--radius-xs);
    font-size: var(--fs-md); font-weight: var(--fw-bold);
    color: var(--signal-amber); text-shadow: var(--text-glow-amber);
  }
  .vbrick__main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .vbrick__name { font-family: var(--font-display); font-size: var(--fs-sm); color: var(--text-bright); font-weight: var(--fw-semibold); }
  .vbrick__focus { font-size: var(--fs-2xs); color: var(--text-mute); letter-spacing: var(--tracking-wide); }
  .vbrick__recent { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; color: var(--signal-cyan); margin-top: 2px; }
  .vbrick__status { font-size: var(--fs-2xs); color: var(--text-faint); text-transform: uppercase; letter-spacing: var(--tracking-widest); font-weight: var(--fw-bold); }

  .explainer-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-2); }
  @media (max-width: 700px) { .explainer-row { grid-template-columns: 1fr; } }

  .exline {
    display: grid; grid-template-columns: auto 1fr auto;
