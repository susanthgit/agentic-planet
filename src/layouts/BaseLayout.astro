---
/**
 * BaseLayout — root layout wrapping every page.
 *
 * Provides the cockpit frame: status bar (top), nav, main content,
 * footer, scan-line overlay, and global theme handling.
 */
import StatusBar from '@components/StatusBar.astro';
import Nav from '@components/Nav.astro';
import CosmosBar from '@components/CosmosBar.astro';
import Footer from '@components/Footer.astro';
import CommandPalette from '@components/interactive/CommandPalette.tsx';
import '@styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'Tools, MCPs, recipes, and honest reviews for techies building AI agents. Plain English, no vendor spin, no hype — just what actually works in production.',
  canonical,
  ogImage,
  noIndex = false,
  bodyClass = '',
} = Astro.props;

// Word-boundary trim for SEO compliance (added 11 May 2026, Phase 3D sweep).
// Long human-readable page titles like "Pick Your Stack — agentic AI stack
// recommender" overflow Google's 60-char title truncation budget once we add
// the brand suffix. Trim at the last space past 60% of maxLen so we don't
// chop mid-word; strip trailing punctuation before adding the ellipsis.
const trimToWord = (s: string, max: number): string => {
  if (s.length <= max) return s;
  const sliced = s.slice(0, max);
  const lastSpace = sliced.lastIndexOf(' ');
  const cut = lastSpace > max * 0.6 ? sliced.slice(0, lastSpace) : sliced;
  return cut.replace(/[\s.,;:—–\-]+$/, '') + '…';
};

const hasBrand = title === 'The Agentic Planet' || title.includes('Agentic Planet');
const rawTitle = hasBrand ? title : `${title} · The Agentic Planet`;
const fullTitle = trimToWord(rawTitle, 60);

// Trim description too — collection-driven pages (MCP reviews, vendor reviews,
// recipes) pass entry.data.summary verbatim, which often exceeds 155 chars.
const trimmedDescription = trimToWord(description, 155);

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={trimmedDescription} />
  <link rel="canonical" href={canonicalUrl} />

  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={trimmedDescription} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
  <meta property="og:site_name" content="The Agentic Planet" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={trimmedDescription} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />}

  <meta name="theme-color" content="#0A0E14" />
  <meta name="color-scheme" content="dark" />
  <link rel="stylesheet" href="/cosmos-bar.css" />
  <link rel="stylesheet" href="/cosmos-footer.css" />

  {/* Cosmos GA4 — aggregate analytics for cosmos-wide intelligence (prod only).
      Single shared property G-2HWWZGWCD0 + event-scoped dim cosmos_planet.
      Ad signals denied; purely analytics_storage. Added 12 May 2026. */}
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-2HWWZGWCD0" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent','default',{ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',analytics_storage:'granted'});
        gtag('js', new Date());
        gtag('config', 'G-2HWWZGWCD0', { cosmos_planet: 'agentic', anonymize_ip: true });
      </script>
    </>
  )}
</head>

<body class={bodyClass}>
  <CosmosBar />
  <a href="#main" class="skip-link">Skip to main content</a>

  <div data-pagefind-ignore>
    <StatusBar />
    <Nav />
  </div>

  <main id="main" tabindex="-1">
    <slot />
  </main>

  <div data-pagefind-ignore>
    <Footer />

    <CommandPalette client:load />
  </div>

  <script>
    // ⌘K is handled by CommandPalette React island. No fallback navigation.
  </script>
</body>
</html>
