---
/**
 * Sparkline — tiny inline SVG chart for trends.
 * Lightweight, no library needed.
 */

export interface Props {
  data: number[];
  width?: number;
  height?: number;
  stroke?: 'green' | 'red' | 'amber' | 'cyan' | 'accent';
  fill?: boolean;
  smooth?: boolean;
  ariaLabel?: string;
}

const {
  data,
  width = 80,
  height = 22,
  stroke = 'cyan',
  fill = true,
  smooth = false,
  ariaLabel = 'Trend',
} = Astro.props;

if (!data || data.length === 0) {
  // Render empty placeholder
}

const safeData = (data && data.length > 0) ? data : [0, 0];
const max = Math.max(...safeData);
const min = Math.min(...safeData);
const range = max - min || 1;
const stepX = width / Math.max(1, safeData.length - 1);

const points = safeData.map((v, i) => {
  const x = i * stepX;
  const y = height - ((v - min) / range) * (height - 2) - 1;
  return [x, y] as const;
});

let pathD = '';
if (smooth && points.length > 2) {
  pathD = `M ${points[0][0]} ${points[0][1]}`;
  for (let i = 1; i < points.length; i++) {
    const [x, y] = points[i];
    const [px, py] = points[i - 1];
    const cpx = (px + x) / 2;
    pathD += ` Q ${cpx} ${py} ${cpx} ${(py + y) / 2}`;
    pathD += ` Q ${cpx} ${y} ${x} ${y}`;
  }
} else {
  pathD = points.map(([x, y], i) => `${i === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`).join(' ');
}

const fillD = fill ? `${pathD} L ${width} ${height} L 0 ${height} Z` : '';

const strokeMap: Record<NonNullable<Props['stroke']>, string> = {
  green: 'var(--signal-green)',
  red: 'var(--signal-red)',
  amber: 'var(--signal-amber)',
  cyan: 'var(--signal-cyan)',
  accent: 'var(--accent-hi)',
};
const color = strokeMap[stroke];

const id = `sparkline-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  class="sparkline"
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  role="img"
  aria-label={ariaLabel}
>
  {fill && (
    <>
      <defs>
        <linearGradient id={id} x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color={color} stop-opacity="0.35" />
          <stop offset="100%" stop-color={color} stop-opacity="0" />
        </linearGradient>
      </defs>
      <path d={fillD} fill={`url(#${id})`} />
    </>
  )}
  <path
    d={pathD}
    fill="none"
    stroke={color}
    stroke-width="1.2"
    stroke-linecap="round"
    stroke-linejoin="round"
    style={`filter: drop-shadow(0 0 3px ${color});`}
  />
</svg>

<style>
  .sparkline {
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
