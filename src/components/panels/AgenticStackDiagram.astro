---
/**
 * AgenticStackDiagram — signature SVG visual for the homepage.
 * Shows the layered architecture of an agent: UI → Orchestrator → LLM →
 * Tools (MCP) ↔ Memory. Each layer is hoverable.
 *
 * Pure SVG, no external deps. Animated subtly via CSS.
 */

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<figure class:list={['stackdiag', className]} role="img" aria-label="The agentic stack: UI, Orchestration, LLM, Tools/MCP, Memory">
  <div class="stackdiag__head">
    <span class="stackdiag__kicker mono">▸ THE AGENTIC STACK</span>
    <span class="stackdiag__caption mono">FIVE LAYERS · ONE LOOP</span>
  </div>

  <svg class="stackdiag__svg" viewBox="0 0 720 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id="layerAccent" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#6366F1" stop-opacity="0.4" />
        <stop offset="100%" stop-color="#6366F1" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="layerCyan" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#22D3EE" stop-opacity="0.4" />
        <stop offset="100%" stop-color="#22D3EE" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="layerMagenta" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#EC4899" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#EC4899" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="layerGreen" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#10B981" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#10B981" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="layerAmber" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#F59E0B" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#F59E0B" stop-opacity="0" />
      </linearGradient>
      <pattern id="cellGrid" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
        <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#1A2332" stroke-width="0.5" opacity="0.5" />
      </pattern>
    </defs>

    <!-- Background grid -->
    <rect width="720" height="380" fill="url(#cellGrid)" />

    <!-- Layer 1: UI / Trigger (top) -->
    <g class="stackdiag__layer stackdiag__layer--ui">
      <rect x="80" y="20" width="560" height="48" rx="2" fill="#0F151E" stroke="#22D3EE" stroke-width="1" />
      <rect x="80" y="20" width="560" height="48" rx="2" fill="url(#layerCyan)" />
      <text x="100" y="42" class="stackdiag__layer-code" fill="#22D3EE">L01</text>
      <text x="140" y="42" class="stackdiag__layer-name">UI · Trigger · Goal</text>
      <text x="140" y="58" class="stackdiag__layer-sub">User input, schedule, API call, webhook</text>
      <!-- Corner brackets -->
      <path d="M 80 20 L 80 28 M 80 20 L 88 20" stroke="#22D3EE" stroke-width="1.5" fill="none" />
      <path d="M 640 20 L 640 28 M 640 20 L 632 20" stroke="#22D3EE" stroke-width="1.5" fill="none" />
      <path d="M 80 68 L 80 60 M 80 68 L 88 68" stroke="#22D3EE" stroke-width="1.5" fill="none" />
      <path d="M 640 68 L 640 60 M 640 68 L 632 68" stroke="#22D3EE" stroke-width="1.5" fill="none" />
    </g>

    <!-- Connection: UI → Orchestrator -->
    <line x1="360" y1="68" x2="360" y2="86" stroke="#4A5568" stroke-width="1" stroke-dasharray="2,2" />
    <polygon points="360,90 357,84 363,84" fill="#4A5568" />

    <!-- Layer 2: Orchestrator -->
    <g class="stackdiag__layer stackdiag__layer--orch">
      <rect x="80" y="92" width="560" height="48" rx="2" fill="#0F151E" stroke="#818CF8" stroke-width="1" />
      <rect x="80" y="92" width="560" height="48" rx="2" fill="url(#layerAccent)" />
      <text x="100" y="114" class="stackdiag__layer-code" fill="#818CF8">L02</text>
      <text x="140" y="114" class="stackdiag__layer-name">Orchestration · Planner</text>
      <text x="140" y="130" class="stackdiag__layer-sub">Loop: observe → plan → act → observe (ReAct, plan-and-execute, reflexion)</text>
      <path d="M 80 92 L 80 100 M 80 92 L 88 92" stroke="#818CF8" stroke-width="1.5" fill="none" />
      <path d="M 640 92 L 640 100 M 640 92 L 632 92" stroke="#818CF8" stroke-width="1.5" fill="none" />
      <path d="M 80 140 L 80 132 M 80 140 L 88 140" stroke="#818CF8" stroke-width="1.5" fill="none" />
      <path d="M 640 140 L 640 132 M 640 140 L 632 140" stroke="#818CF8" stroke-width="1.5" fill="none" />
    </g>

    <line x1="360" y1="140" x2="360" y2="158" stroke="#4A5568" stroke-width="1" stroke-dasharray="2,2" />
    <polygon points="360,162 357,156 363,156" fill="#4A5568" />

    <!-- Layer 3: LLM (the brain) -->
    <g class="stackdiag__layer stackdiag__layer--llm">
      <rect x="80" y="164" width="560" height="60" rx="2" fill="#0F151E" stroke="#EC4899" stroke-width="1.5" />
      <rect x="80" y="164" width="560" height="60" rx="2" fill="url(#layerMagenta)" />
      <text x="100" y="190" class="stackdiag__layer-code" fill="#EC4899">L03</text>
      <text x="140" y="190" class="stackdiag__layer-name stackdiag__layer-name--feature">LLM · The Brain</text>
      <text x="140" y="208" class="stackdiag__layer-sub">Claude · GPT · Gemini · Llama — predicts next tokens, calls tools</text>
      <text x="500" y="190" class="stackdiag__layer-tag" fill="#EC4899">FEATURE</text>
      <path d="M 80 164 L 80 174 M 80 164 L 90 164" stroke="#EC4899" stroke-width="2" fill="none" />
      <path d="M 640 164 L 640 174 M 640 164 L 630 164" stroke="#EC4899" stroke-width="2" fill="none" />
      <path d="M 80 224 L 80 214 M 80 224 L 90 224" stroke="#EC4899" stroke-width="2" fill="none" />
      <path d="M 640 224 L 640 214 M 640 224 L 630 224" stroke="#EC4899" stroke-width="2" fill="none" />
      <!-- Pulse ring -->
      <circle cx="500" cy="180" r="3" fill="#EC4899">
        <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite" />
      </circle>
    </g>

    <line x1="240" y1="224" x2="240" y2="248" stroke="#4A5568" stroke-width="1" stroke-dasharray="2,2" />
    <polygon points="240,252 237,246 243,246" fill="#4A5568" />
    <line x1="480" y1="224" x2="480" y2="248" stroke="#4A5568" stroke-width="1" stroke-dasharray="2,2" />
    <polygon points="480,252 477,246 483,246" fill="#4A5568" />

    <!-- Layer 4: Tools / MCP — split -->
    <g class="stackdiag__layer stackdiag__layer--tools">
      <rect x="80" y="254" width="270" height="48" rx="2" fill="#0F151E" stroke="#10B981" stroke-width="1" />
      <rect x="80" y="254" width="270" height="48" rx="2" fill="url(#layerGreen)" />
      <text x="100" y="276" class="stackdiag__layer-code" fill="#10B981">L04</text>
      <text x="140" y="276" class="stackdiag__layer-name">Tools · MCP Servers</text>
      <text x="140" y="292" class="stackdiag__layer-sub">github, playwright, postgres…</text>
      <path d="M 80 254 L 80 262 M 80 254 L 88 254" stroke="#10B981" stroke-width="1.5" fill="none" />
      <path d="M 350 254 L 350 262 M 350 254 L 342 254" stroke="#10B981" stroke-width="1.5" fill="none" />
      <path d="M 80 302 L 80 294 M 80 302 L 88 302" stroke="#10B981" stroke-width="1.5" fill="none" />
      <path d="M 350 302 L 350 294 M 350 302 L 342 302" stroke="#10B981" stroke-width="1.5" fill="none" />
    </g>

    <!-- Layer 5: Memory (right of Tools) -->
    <g class="stackdiag__layer stackdiag__layer--memory">
      <rect x="370" y="254" width="270" height="48" rx="2" fill="#0F151E" stroke="#F59E0B" stroke-width="1" />
      <rect x="370" y="254" width="270" height="48" rx="2" fill="url(#layerAmber)" />
      <text x="390" y="276" class="stackdiag__layer-code" fill="#F59E0B">L05</text>
      <text x="430" y="276" class="stackdiag__layer-name">Memory · Context</text>
      <text x="430" y="292" class="stackdiag__layer-sub">Short-term turns, long-term embeddings, RAG</text>
      <path d="M 370 254 L 370 262 M 370 254 L 378 254" stroke="#F59E0B" stroke-width="1.5" fill="none" />
      <path d="M 640 254 L 640 262 M 640 254 L 632 254" stroke="#F59E0B" stroke-width="1.5" fill="none" />
      <path d="M 370 302 L 370 294 M 370 302 L 378 302" stroke="#F59E0B" stroke-width="1.5" fill="none" />
      <path d="M 640 302 L 640 294 M 640 302 L 632 302" stroke="#F59E0B" stroke-width="1.5" fill="none" />
    </g>

    <!-- Loop arrow (back to orchestrator) -->
    <path d="M 220 302 Q 60 302 60 116 Q 60 92 80 92" stroke="#22D3EE" stroke-width="1" fill="none" stroke-dasharray="3,3" opacity="0.6" />
    <polygon points="80,92 72,89 72,95" fill="#22D3EE" opacity="0.6" />
    <text x="20" y="200" class="stackdiag__loop-label" fill="#22D3EE">LOOP</text>

    <!-- Title overlay -->
    <text x="80" y="338" class="stackdiag__title-text">⌬ AGENT.ARCH</text>
    <text x="80" y="358" class="stackdiag__sub-text">Single agent = LLM + Loop + Tools. Anything else is decoration.</text>
  </svg>
</figure>

<style>
  .stackdiag {
    margin: 0;
    padding: 0;
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .stackdiag__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2-5) var(--space-3);
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .stackdiag__kicker {
    color: var(--accent-hi);
    font-weight: var(--fw-semibold);
    text-shadow: var(--text-glow-accent);
  }

  .stackdiag__caption {
    color: var(--text-mute);
  }

  .stackdiag__svg {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-base);
  }

  /* SVG text styles via global rules so they apply inside SVG */
  :global(.stackdiag__svg .stackdiag__layer-code) {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  :global(.stackdiag__svg .stackdiag__layer-name) {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    fill: #F9FAFB;
    letter-spacing: -0.01em;
  }

  :global(.stackdiag__svg .stackdiag__layer-name--feature) {
    font-size: 14px;
    fill: #F9FAFB;
  }

  :global(.stackdiag__svg .stackdiag__layer-sub) {
    font-family: var(--font-body);
    font-size: 11px;
    fill: #9CA3AF;
  }

  :global(.stackdiag__svg .stackdiag__layer-tag) {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  :global(.stackdiag__svg .stackdiag__loop-label) {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
  }

  :global(.stackdiag__svg .stackdiag__title-text) {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    fill: var(--accent-hi);
    letter-spacing: 0.05em;
  }

  :global(.stackdiag__svg .stackdiag__sub-text) {
    font-family: var(--font-body);
    font-size: 12px;
    fill: var(--text-mute);
    font-style: italic;
  }

  /* Hover effects on layers */
  :global(.stackdiag__svg .stackdiag__layer) {
    transition: filter 200ms ease-out;
    cursor: default;
  }

  :global(.stackdiag__svg .stackdiag__layer:hover) {
    filter: brightness(1.2);
  }
</style>
