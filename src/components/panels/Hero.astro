---
/**
 * Hero — big landing hero with cockpit signature elements.
 * Used on homepage.
 */

import Kicker from '@components/primitives/Kicker.astro';
import LiveDot from '@components/data/LiveDot.astro';

export interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  meta?: string;
}

const { kicker = 'AGENTIC PLANET // CHANNEL OPEN', title, subtitle, meta } = Astro.props;
---

<section class="hero">
  <div class="hero__scan" aria-hidden="true"></div>

  <div class="hero__inner container-wide">
    <div class="hero__head">
      <Kicker text={kicker} color="accent" />
      {meta && (
        <span class="hero__meta">
          <LiveDot color="green" />
          <span class="mono">{meta}</span>
        </span>
      )}
    </div>

    <h1 class="hero__title">
      <span class="hero__title-line">{title}</span>
      <span class="hero__cursor" aria-hidden="true">▌</span>
    </h1>

    {subtitle && (
      <p class="hero__subtitle">{subtitle}</p>
    )}

    <div class="hero__cta">
      <slot name="cta" />
    </div>

    <div class="hero__panels">
      <slot name="panels" />
    </div>
  </div>

  <div class="hero__crt" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99, 102, 241, 0.08), transparent 60%),
      var(--bg-base);
    border-bottom: 1px solid var(--border-dim);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
  }

  .hero__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .hero__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-2xs);
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 7vw, 88px);
    font-weight: var(--fw-bold);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--text-bright);
    margin-bottom: var(--space-4);
    max-width: 1100px;
    text-shadow: 0 0 40px rgba(129, 140, 248, 0.18);
    animation: flicker 8s var(--ease-in-out) infinite;
  }

  .hero__title-line {
    display: inline;
  }

  .hero__cursor {
    display: inline-block;
    margin-left: 6px;
    color: var(--accent-hi);
    animation: blink 1.1s infinite step-start;
    text-shadow: var(--text-glow-accent);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    line-height: 1.5;
    color: var(--text-mute);
    max-width: 720px;
    margin-bottom: var(--space-8);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .hero__panels {
    margin-top: var(--space-8);
  }

  /* Subtle scan line that drifts down — pure decoration */
  .hero__scan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--accent),
      var(--signal-cyan),
      transparent
    );
    opacity: 0.7;
    box-shadow: 0 0 12px var(--accent-glow);
  }

  /* CRT grid faint pattern overlay */
  .hero__crt {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 50%, transparent 30%, rgba(0, 0, 0, 0.3) 100%);
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .hero { padding: var(--space-10) 0 var(--space-8); }
  }
</style>
