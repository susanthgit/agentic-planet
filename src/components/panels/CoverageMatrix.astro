---
/**
 * CoverageMatrix — at-a-glance progress on every pillar.
 * Each row: pillar code · name · ratio (n / target) · progress bar
 * Used between bento rows on the homepage.
 */

import Icon from '@components/primitives/Icon.astro';
import type { IconName } from '@components/primitives/icons';

interface Pillar {
  code: string;
  title: string;
  href: string;
  current: number;
  target: number;
  color: 'accent' | 'cyan' | 'green' | 'amber' | 'red' | 'magenta' | 'violet';
  icon?: IconName;
  status?: string;
}

export interface Props {
  pillars: Pillar[];
}

const { pillars } = Astro.props;
---

<div class="cmat">
  <header class="cmat__head">
    <span class="cmat__kicker mono">▸ COVERAGE MATRIX // SCOPE TRACKER</span>
    <span class="cmat__sub mono">CURRENT / TARGET PER PILLAR</span>
  </header>

  <div class="cmat__rows">
    {pillars.map((p) => {
      const pct = Math.min(100, Math.max(0, (p.current / p.target) * 100));
      const ratio = `${p.current} / ${p.target}`;
      return (
        <a class={`cmat-row cmat-row--${p.color}`} href={p.href}>
          <span class="cmat-row__code mono">{p.code}</span>
          {p.icon && (
            <span class="cmat-row__icon" aria-hidden="true">
              <Icon name={p.icon} size={12} stroke={1.6} />
            </span>
          )}
          <span class="cmat-row__name">{p.title}</span>
          <span class="cmat-row__ratio mono">{ratio}</span>
          <div class="cmat-row__bar" aria-hidden="true">
            <span class="cmat-row__bar-fill" style={`width: ${pct}%;`}></span>
          </div>
          <span class="cmat-row__pct mono">{Math.round(pct)}%</span>
          {p.status && <span class="cmat-row__status mono">{p.status}</span>}
        </a>
      );
    })}
  </div>
</div>

<style>
  .cmat {
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .cmat__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .cmat__kicker {
    color: var(--accent-hi);
    font-weight: var(--fw-semibold);
    text-shadow: var(--text-glow-accent);
  }

  .cmat__sub { color: var(--text-mute); }

  .cmat__rows {
    display: flex;
    flex-direction: column;
  }

  .cmat-row {
    display: grid;
    grid-template-columns: 36px 18px 1fr 70px 140px 38px auto;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--border-dim);
    color: var(--text);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .cmat-row:last-child { border-bottom: 0; }

  .cmat-row:hover {
    background: var(--bg-elevated);
    color: var(--text-bright);
  }

  .cmat-row--accent { color: var(--accent-hi); }
  .cmat-row--cyan { color: var(--signal-cyan); }
  .cmat-row--green { color: var(--signal-green); }
  .cmat-row--amber { color: var(--signal-amber); }
  .cmat-row--red { color: var(--signal-red); }
  .cmat-row--magenta { color: var(--signal-magenta); }
  .cmat-row--violet { color: var(--signal-violet); }

  .cmat-row__code {
    font-size: 9px;
    color: currentColor;
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .cmat-row__icon {
    color: currentColor;
    line-height: 0;
    filter: drop-shadow(0 0 3px currentColor);
  }

  .cmat-row__name {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    color: var(--text-bright);
    font-weight: var(--fw-medium);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .cmat-row__ratio {
    font-size: var(--fs-xs);
    color: var(--text-mute);
    text-align: right;
  }

  .cmat-row__bar {
    height: 4px;
    background: var(--border-dim);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .cmat-row__bar-fill {
    display: block;
    height: 100%;
    background: currentColor;
    box-shadow: 0 0 4px currentColor;
    transition: width var(--duration-slow) var(--ease-out);
  }

  .cmat-row__pct {
    font-size: var(--fs-2xs);
    color: currentColor;
    font-weight: var(--fw-bold);
    text-align: right;
    text-shadow: 0 0 4px currentColor;
  }

  .cmat-row__status {
    font-size: 9px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    padding: 2px 5px;
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-xs);
  }

  @media (max-width: 800px) {
    .cmat-row {
      grid-template-columns: 28px 14px 1fr 60px 80px 38px;
    }
    .cmat-row__status { display: none; }
  }
</style>
