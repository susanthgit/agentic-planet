---
/**
 * PillarTile — large clickable tile for a pillar (used on homepage).
 * Cockpit-style with code, icon, count, and bar fill.
 */

export interface Props {
  href: string;
  code: string;
  title: string;
  description: string;
  count?: number;
  fillPercent?: number;
  color?: 'accent' | 'cyan' | 'green' | 'amber' | 'magenta' | 'violet';
  icon?: string;
}

const {
  href,
  code,
  title,
  description,
  count,
  fillPercent = 50,
  color = 'accent',
  icon,
} = Astro.props;
---

<a class:list={['pt', `pt--${color}`]} href={href}>
  <span class="pt__corner pt__corner--tl" aria-hidden="true"></span>
  <span class="pt__corner pt__corner--br" aria-hidden="true"></span>

  <div class="pt__head">
    <span class="pt__code">{code}</span>
    {count !== undefined && (
      <span class="pt__count mono">{count.toLocaleString()}</span>
    )}
  </div>

  <div class="pt__body">
    {icon && <span class="pt__icon" aria-hidden="true">{icon}</span>}
    <h3 class="pt__title">{title}</h3>
    <p class="pt__desc">{description}</p>
  </div>

  <div class="pt__bar" aria-hidden="true">
    <span class="pt__bar-fill" style={`width: ${Math.min(100, Math.max(0, fillPercent))}%`}></span>
  </div>

  <span class="pt__chev" aria-hidden="true">→</span>
</a>

<style>
  .pt {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border-dim);
    transition: all var(--duration-fast) var(--ease-out);
    overflow: hidden;
    min-height: 180px;
  }

  .pt:hover {
    border-color: currentColor;
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  .pt::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: currentColor;
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover::before {
    opacity: 1;
    box-shadow: 0 0 12px currentColor;
  }

  .pt--accent { color: var(--accent-hi); }
  .pt--cyan { color: var(--signal-cyan); }
  .pt--green { color: var(--signal-green); }
  .pt--amber { color: var(--signal-amber); }
  .pt--magenta { color: var(--signal-magenta); }
  .pt--violet { color: var(--signal-violet); }

  .pt__corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid currentColor;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__corner { opacity: 0.7; }

  .pt__corner--tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }

  .pt__corner--br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  .pt__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .pt__code {
    color: currentColor;
    font-weight: var(--fw-semibold);
  }

  .pt__count {
    color: var(--text-bright);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    text-shadow: 0 0 12px currentColor;
  }

  .pt__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .pt__icon {
    font-size: var(--fs-xl);
    line-height: 1;
  }

  .pt__title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    margin: 0;
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
  }

  .pt__desc {
    font-size: var(--fs-xs);
    color: var(--text-mute);
    line-height: 1.5;
    margin: 0;
  }

  .pt__bar {
    height: 2px;
    background: var(--border-dim);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .pt__bar-fill {
    display: block;
    height: 100%;
    background: currentColor;
    box-shadow: 0 0 6px currentColor;
    transition: width var(--duration-slow) var(--ease-out);
  }

  .pt__chev {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    color: currentColor;
    font-family: var(--font-mono);
    font-size: var(--fs-md);
    opacity: 0.4;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__chev {
    opacity: 1;
    transform: translateX(3px);
    text-shadow: 0 0 6px currentColor;
  }
</style>
