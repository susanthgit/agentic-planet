---
/**
 * PillarTile — large clickable tile for a pillar (used on homepage).
 * Cockpit-style: code, SVG icon, count, bar fill.
 */
import Icon from '@components/primitives/Icon.astro';
import type { IconName } from '@components/primitives/icons';

export interface Props {
  href: string;
  code: string;
  title: string;
  description: string;
  count?: number;
  fillPercent?: number;
  color?: 'accent' | 'cyan' | 'green' | 'amber' | 'magenta' | 'violet';
  icon?: IconName;
}

const {
  href,
  code,
  title,
  description,
  count,
  fillPercent = 50,
  color = 'accent',
  icon,
} = Astro.props;
---

<a class:list={['pt', `pt--${color}`]} href={href}>
  <span class="pt__corner pt__corner--tl" aria-hidden="true"></span>
  <span class="pt__corner pt__corner--br" aria-hidden="true"></span>

  <div class="pt__head">
    <span class="pt__code">{code}</span>
    {count !== undefined && (
      <span class="pt__count mono">{count.toLocaleString()}</span>
    )}
  </div>

  <div class="pt__body">
    {icon && (
      <span class="pt__icon" aria-hidden="true">
        <Icon name={icon} size={22} stroke={1.6} />
      </span>
    )}
    <h3 class="pt__title">{title}</h3>
    <p class="pt__desc">{description}</p>
  </div>

  <div class="pt__bar" aria-hidden="true">
    <span class="pt__bar-fill" style={`width: ${Math.min(100, Math.max(0, fillPercent))}%`}></span>
  </div>

  <span class="pt__chev" aria-hidden="true">
    <Icon name="arrow-right" size={14} stroke={2} />
  </span>
</a>

<style>
  .pt {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-3) var(--space-3);
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border-dim);
    transition: all var(--duration-fast) var(--ease-out);
    overflow: hidden;
    min-height: 132px;
  }

  .pt:hover {
    border-color: currentColor;
    background: var(--bg-elevated);
    transform: translateY(-1px);
  }

  .pt::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background: currentColor;
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover::before {
    opacity: 1;
    box-shadow: 0 0 8px currentColor;
  }

  .pt--accent { color: var(--accent-hi); }
  .pt--cyan { color: var(--signal-cyan); }
  .pt--green { color: var(--signal-green); }
  .pt--amber { color: var(--signal-amber); }
  .pt--magenta { color: var(--signal-magenta); }
  .pt--violet { color: var(--signal-violet); }

  .pt__corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 1px solid currentColor;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__corner { opacity: 0.8; }

  .pt__corner--tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }

  .pt__corner--br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  .pt__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .pt__code {
    color: currentColor;
    font-weight: var(--fw-semibold);
  }

  .pt__count {
    color: var(--text-bright);
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    text-shadow: 0 0 8px currentColor;
  }

  .pt__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .pt__icon {
    color: currentColor;
    margin-bottom: var(--space-1);
    line-height: 0;
    filter: drop-shadow(0 0 4px currentColor);
  }

  .pt__title {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    margin: 0;
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
  }

  .pt__desc {
    font-size: 11px;
    color: var(--text-mute);
    line-height: 1.45;
    margin: 0;
  }

  .pt__bar {
    height: 2px;
    background: var(--border-dim);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .pt__bar-fill {
    display: block;
    height: 100%;
    background: currentColor;
    box-shadow: 0 0 4px currentColor;
    transition: width var(--duration-slow) var(--ease-out);
  }

  .pt__chev {
    position: absolute;
    bottom: var(--space-2-5);
    right: var(--space-2-5);
    color: currentColor;
    line-height: 0;
    opacity: 0.4;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__chev {
    opacity: 1;
    transform: translateX(2px);
    filter: drop-shadow(0 0 4px currentColor);
  }
</style>
