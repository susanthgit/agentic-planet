---
/**
 * PillarTile — compact single-line pillar tile (cockpit dense).
 * Layout: [code] [icon] [title] [count] [arrow] over a thin progress bar.
 */
import Icon from '@components/primitives/Icon.astro';
import type { IconName } from '@components/primitives/icons';

export interface Props {
  href: string;
  code: string;
  title: string;
  description?: string;
  count?: number;
  target?: number;
  fillPercent?: number;
  color?: 'accent' | 'cyan' | 'green' | 'amber' | 'magenta' | 'violet';
  icon?: IconName;
  feature?: boolean;
}

const {
  href,
  code,
  title,
  description,
  count,
  fillPercent = 50,
  color = 'accent',
  icon,
  feature = false,
} = Astro.props;
---

<a class:list={['pt', `pt--${color}`, { 'pt--feature': feature }]} href={href}>
  <span class="pt__corner pt__corner--tl" aria-hidden="true"></span>
  <span class="pt__corner pt__corner--br" aria-hidden="true"></span>

  <div class="pt__body">
    <span class="pt__code mono">{code}</span>
    {icon && (
      <span class="pt__icon" aria-hidden="true">
        <Icon name={icon} size={feature ? 18 : 14} stroke={1.6} />
      </span>
    )}
    <span class="pt__title">{title}</span>
    {count !== undefined && (
      <span class="pt__count mono">{count.toLocaleString()}{Astro.props.target !== undefined && <span class="pt__count-target">/{Astro.props.target}</span>}</span>
    )}
    <span class="pt__chev" aria-hidden="true">
      <Icon name="arrow-right" size={12} stroke={2} />
    </span>
  </div>

  {feature && description && (
    <p class="pt__desc">{description}</p>
  )}

  <div class="pt__bar" aria-hidden="true">
    <span class="pt__bar-fill" style={`width: ${Math.min(100, Math.max(0, fillPercent))}%`}></span>
  </div>
</a>

<style>
  .pt {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border-dim);
    transition: all var(--duration-fast) var(--ease-out);
    overflow: hidden;
  }

  .pt--feature {
    background: linear-gradient(180deg, var(--bg-panel) 0%, var(--bg-elevated) 100%);
  }

  .pt:hover {
    border-color: currentColor;
    background: var(--bg-elevated);
    transform: translateY(-1px);
  }

  .pt::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background: currentColor;
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover::before {
    opacity: 1;
    box-shadow: 0 0 8px currentColor;
  }

  .pt--accent { color: var(--accent-hi); }
  .pt--cyan { color: var(--signal-cyan); }
  .pt--green { color: var(--signal-green); }
  .pt--amber { color: var(--signal-amber); }
  .pt--magenta { color: var(--signal-magenta); }
  .pt--violet { color: var(--signal-violet); }

  .pt__corner {
    position: absolute;
    width: 7px;
    height: 7px;
    border: 1px solid currentColor;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__corner { opacity: 0.85; }

  .pt__corner--tl { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .pt__corner--br { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }

  .pt__body {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2-5) var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .pt--feature .pt__body {
    padding: var(--space-3) var(--space-3) var(--space-2);
  }

  .pt__code {
    font-size: 9px;
    color: currentColor;
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    line-height: 1;
  }

  .pt__icon {
    color: currentColor;
    line-height: 0;
    filter: drop-shadow(0 0 3px currentColor);
  }

  .pt__title {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .pt--feature .pt__title {
    font-size: var(--fs-md);
  }

  .pt__count-target {
    color: var(--text-faint);
    font-weight: var(--fw-normal);
    text-shadow: none;
    margin-left: 1px;
  }

  .pt__count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-bright);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }

  .pt__chev {
    color: currentColor;
    line-height: 0;
    opacity: 0.4;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .pt:hover .pt__chev {
    opacity: 1;
    transform: translateX(2px);
    filter: drop-shadow(0 0 4px currentColor);
  }

  .pt__desc {
    padding: 0 var(--space-3) var(--space-2-5);
    font-size: 11px;
    color: var(--text-mute);
    line-height: 1.4;
    margin: 0;
  }

  .pt__bar {
    height: 2px;
    background: var(--border-dim);
    border-radius: 0;
    overflow: hidden;
  }

  .pt__bar-fill {
    display: block;
    height: 100%;
    background: currentColor;
    box-shadow: 0 0 4px currentColor;
    transition: width var(--duration-slow) var(--ease-out);
  }
</style>
