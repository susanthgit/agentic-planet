---
/**
 * PulseRail — vertical pulse list for hero (replaces full-width ticker).
 * Shows latest 4 items from the pulse JSON, with icons.
 */

import Icon from '@components/primitives/Icon.astro';
import LiveDot from '@components/data/LiveDot.astro';

interface PulseItem {
  icon?: string;
  text: string;
  color?: string;
  href?: string;
}

export interface Props {
  items: PulseItem[];
  limit?: number;
}

const { items, limit = 4 } = Astro.props;
const visible = items.slice(0, limit);

function colorClass(c?: string): string {
  if (c === 'green') return 'pulse-row--green';
  if (c === 'red') return 'pulse-row--red';
  if (c === 'amber') return 'pulse-row--amber';
  if (c === 'cyan') return 'pulse-row--cyan';
  if (c === 'magenta') return 'pulse-row--magenta';
  return 'pulse-row--accent';
}
---

<div class="pulse-rail">
  <header class="pulse-rail__head">
    <span class="pulse-rail__kicker mono">
      <LiveDot color="cyan" size="sm" />
      <span>PULSE · LIVE</span>
    </span>
    <span class="pulse-rail__count mono">{items.length}</span>
  </header>

  <ul class="pulse-rail__list">
    {visible.map((p) => (
      <li class={`pulse-row ${colorClass(p.color)}`}>
        <span class="pulse-row__bullet" aria-hidden="true">{p.icon || '◇'}</span>
        {p.href ? (
          <a class="pulse-row__text" href={p.href}>{p.text}</a>
        ) : (
          <span class="pulse-row__text">{p.text}</span>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
  .pulse-rail {
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .pulse-rail__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .pulse-rail__kicker {
    color: var(--signal-cyan);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-shadow: var(--text-glow-cyan);
    font-weight: var(--fw-semibold);
  }

  .pulse-rail__count {
    color: var(--text-mute);
  }

  .pulse-rail__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .pulse-row {
    display: grid;
    grid-template-columns: 16px 1fr;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--border-dim);
    font-size: var(--fs-xs);
    line-height: 1.3;
  }

  .pulse-row:last-child { border-bottom: 0; }

  .pulse-row__bullet {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1;
    color: currentColor;
    text-align: center;
  }

  .pulse-row--green { color: var(--signal-green); }
  .pulse-row--red { color: var(--signal-red); }
  .pulse-row--amber { color: var(--signal-amber); }
  .pulse-row--cyan { color: var(--signal-cyan); }
  .pulse-row--magenta { color: var(--signal-magenta); }
  .pulse-row--accent { color: var(--accent-hi); }

  .pulse-row__text {
    color: var(--text);
    font-family: var(--font-body);
    overflow: hidden;
    text-overflow: ellipsis;
    border-bottom: 0;
  }

  a.pulse-row__text:hover {
    color: var(--text-bright);
    border-bottom: 0;
  }
</style>
