---
/**
 * RecipeCard — summary card for a recipe.
 * Shows: title, components, before→after, status.
 */

import Tag from '@components/primitives/Tag.astro';
import HealthBadge from '@components/data/HealthBadge.astro';

export interface Props {
  slug: string;
  title: string;
  components: string[];
  before: string;
  after: string;
  cost?: string;
  status?: 'production' | 'experimental' | 'draft';
  description?: string;
  rating?: number;
}

const {
  slug,
  title,
  components,
  before,
  after,
  cost,
  status = 'production',
  description,
} = Astro.props;

const statusMap: Record<NonNullable<Props['status']>, { label: string; color: string }> = {
  production: { label: 'Production', color: 'green' },
  experimental: { label: 'Experimental', color: 'amber' },
  draft: { label: 'Draft', color: 'red' },
};

const statusInfo = statusMap[status];
---

<a class="rc" href={`/recipes/${slug}/`}>
  <div class="rc__head">
    <span class="rc__icon" aria-hidden="true">🍳</span>
    <h3 class="rc__title">{title}</h3>
  </div>

  {description && <p class="rc__desc">{description}</p>}

  <div class="rc__metrics">
    <div class="rc__metric rc__metric--before">
      <span class="rc__metric-label">Before</span>
      <span class="rc__metric-val">{before}</span>
    </div>
    <span class="rc__arrow" aria-hidden="true">→</span>
    <div class="rc__metric rc__metric--after">
      <span class="rc__metric-label">After</span>
      <span class="rc__metric-val phosphor-green">{after}</span>
    </div>
    {cost && (
      <div class="rc__metric rc__metric--cost">
        <span class="rc__metric-label">Cost / run</span>
        <span class="rc__metric-val mono">{cost}</span>
      </div>
    )}
  </div>

  <div class="rc__components">
    {components.map((c) => <Tag text={c} color="cyan" />)}
  </div>

  <div class="rc__foot">
    <span class={`rc__status rc__status--${statusInfo.color}`}>
      <span class="rc__status-dot" aria-hidden="true"></span>
      {statusInfo.label}
    </span>
    <span class="rc__open">Open recipe →</span>
  </div>
</a>

<style>
  .rc {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--bg-panel);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text);
    border-bottom: 1px solid var(--border-dim);
    transition: border-color var(--duration-fast) var(--ease-out),
                background var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .rc::before {
    content: "";
    position: absolute;
    top: -1px;
    left: -1px;
    right: -1px;
    bottom: -1px;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    pointer-events: none;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .rc:hover {
    border-color: var(--accent);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }

  .rc:hover::before {
    box-shadow: var(--glow-accent);
  }

  .rc__head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2-5);
  }

  .rc__icon {
    font-size: var(--fs-lg);
    line-height: 1;
    flex-shrink: 0;
  }

  .rc__title {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
    line-height: 1.25;
    margin: 0;
    letter-spacing: var(--tracking-tight);
  }

  .rc__desc {
    font-size: var(--fs-sm);
    color: var(--text-mute);
    line-height: 1.5;
    margin: 0;
  }

  .rc__metrics {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-base);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-xs);
    flex-wrap: wrap;
  }

  .rc__metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .rc__metric-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--fw-semibold);
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .rc__metric-val {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--text-bright);
  }

  .rc__metric--before .rc__metric-val {
    color: var(--text-mute);
    text-decoration: line-through;
    text-decoration-color: var(--signal-red);
  }

  .rc__arrow {
    color: var(--accent-hi);
    font-size: var(--fs-md);
    text-shadow: var(--text-glow-accent);
  }

  .rc__components {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1-5);
  }

  .rc__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    border-top: 1px dashed var(--border-dim);
  }

  .rc__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .rc__status-dot {
    width: 5px;
    height: 5px;
    border-radius: var(--radius-full);
    background: currentColor;
  }

  .rc__status--green { color: var(--signal-green); }
  .rc__status--amber { color: var(--signal-amber); }
  .rc__status--red { color: var(--signal-red); }

  .rc__open {
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .rc:hover .rc__open {
    color: var(--accent-hi);
  }
</style>
