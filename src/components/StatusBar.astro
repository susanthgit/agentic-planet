---
/**
 * StatusBar — top strip showing live system telemetry.
 * Cockpit signature element. Always visible at top of page.
 *
 * Shows: live time, indexed pages count, last MCP health update,
 * build version, theme toggle.
 */

import { execSync } from 'node:child_process';
import packageJson from '../../package.json';

let gitSha = 'dev';
try {
  gitSha = execSync('git rev-parse --short HEAD', { stdio: ['ignore', 'pipe', 'ignore'] })
    .toString()
    .trim();
} catch (_) {
  // No git available
}

const buildTime = new Date();
const buildIso = buildTime.toISOString();
const buildLabel = buildTime.toUTCString().replace('GMT', 'UTC');
const version = packageJson.version;
---

<aside class="statusbar" role="complementary" aria-label="System status">
  <div class="statusbar__inner">
    <div class="statusbar__group statusbar__group--left">
      <span class="statusbar__item">
        <span class="statusbar__live-dot" aria-hidden="true"></span>
        <span class="statusbar__label">SYSTEM</span>
        <span class="statusbar__value phosphor-green">ONLINE</span>
      </span>
      <span class="statusbar__sep" aria-hidden="true">│</span>
      <span
        class="statusbar__item statusbar__item--build"
        title={`Built: ${buildIso}\nGit SHA: ${gitSha}\nBranch: main\nDeployed via direct upload to Cloudflare Pages`}
      >
        <span class="statusbar__label">BUILD</span>
        <span class="statusbar__value mono">v{version}-{gitSha}</span>
      </span>
      <span class="statusbar__sep" aria-hidden="true">│</span>
      <span class="statusbar__item">
        <span class="statusbar__label">DEPLOY</span>
        <span class="statusbar__value mono">{buildLabel}</span>
      </span>
    </div>

    <div class="statusbar__group statusbar__group--center">
      <span class="statusbar__heartbeat" aria-hidden="true"></span>
    </div>

    <div class="statusbar__group statusbar__group--right">
      <span class="statusbar__item">
        <span class="statusbar__label">UTC</span>
        <span class="statusbar__value mono" data-utc-clock>00:00:00</span>
      </span>
      <span class="statusbar__sep" aria-hidden="true">│</span>
      <span class="statusbar__item">
        <span class="statusbar__label">VER</span>
        <span class="statusbar__value mono">v{version}</span>
      </span>
    </div>
  </div>
</aside>

<style>
  .statusbar {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    height: var(--statusbar-height);
    background: var(--void);
    border-bottom: 1px solid var(--border-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    overflow: hidden;
  }

  .statusbar__inner {
    height: 100%;
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--space-4);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
  }

  .statusbar__group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-dim);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .statusbar__group--right {
    justify-content: flex-end;
  }

  .statusbar__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
  }

  .statusbar__label {
    color: var(--text-faint);
    font-weight: var(--fw-medium);
  }

  .statusbar__value {
    color: var(--text-mute);
    font-weight: var(--fw-medium);
  }

  .statusbar__sep {
    color: var(--border);
    user-select: none;
  }

  .statusbar__live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--signal-green);
    box-shadow: 0 0 6px var(--signal-green-glow);
    animation: pulse var(--pulse-duration) var(--ease-in-out) infinite;
  }

  .statusbar__heartbeat {
    width: 60px;
    height: 12px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 12' fill='none' stroke='%2310B981' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'><polyline points='0,6 12,6 16,6 18,2 22,10 26,4 30,8 34,6 60,6'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
    opacity: 0.8;
    animation: flicker 4s var(--ease-in-out) infinite;
  }

  .statusbar__toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    padding: 2px var(--space-2);
    border-radius: var(--radius-xs);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }

  .statusbar__toggle:hover {
    color: var(--text-bright);
    background: var(--bg-overlay);
  }

  .statusbar__toggle-icon {
    font-size: var(--fs-sm);
  }

  @media (max-width: 768px) {
    .statusbar__inner {
      grid-template-columns: 1fr auto;
    }
    .statusbar__group--center { display: none; }
    .statusbar__group--left .statusbar__item:nth-child(n+3) { display: none; }
  }
</style>

<script>
  function tickClock() {
    const els = document.querySelectorAll<HTMLElement>('[data-utc-clock]');
    if (!els.length) return;
    const now = new Date();
    const hh = String(now.getUTCHours()).padStart(2, '0');
    const mm = String(now.getUTCMinutes()).padStart(2, '0');
    const ss = String(now.getUTCSeconds()).padStart(2, '0');
    const text = `${hh}:${mm}:${ss}`;
    els.forEach(el => { el.textContent = text; });
  }
  tickClock();
  setInterval(tickClock, 1000);
</script>
