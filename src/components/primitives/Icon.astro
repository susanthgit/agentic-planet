const role = ariaLabel ? 'img' : 'presentation';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['icon', `icon-${name}`, className]}
  role={role}
  aria-label={ariaLabel}
  aria-hidden={!ariaLabel}
  set:html={innerSvg}
></svg>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
